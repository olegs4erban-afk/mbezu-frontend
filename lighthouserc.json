{
  "ci": {
    "collect": {
      "startServerCommand": "npm run preview",
      "startServerReadyPattern": "Local",
      "startServerReadyTimeout": 30000,
      "url": [
        "http://localhost:4173/",
        "http://localhost:4173/about.html",
        "http://localhost:4173/catalog.html",
        "http://localhost:4173/painting.html?id=MN-01"
      ],
      "numberOfRuns": 1,
      "settings": { "chromeFlags": "--no-sandbox --headless=new" }
    },
    "assert": {
      "comment": "CI floors (буфер на разброс runner-ов). Реальные цели выше — см. AUDIT.md: Perf>=90, A11y>=95, BP>=95, SEO 100.",
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.85 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.93 }],
        "categories:seo": ["error", { "minScore": 0.98 }]
      }
    },
    "upload": { "target": "filesystem", "outputDir": "./audit/lhci" }
  }
}
