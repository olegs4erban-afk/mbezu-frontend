{
  "name": "mbezu-frontend",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "Production frontend for mbezu.ru (Mila Bezú) — Vite + React, per-page chunks, prerender, SEO.",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node --import tsx scripts/prerender.tsx",
    "build:only": "vite build",
    "prerender": "node --import tsx scripts/prerender.tsx",
    "smoke": "node --import tsx scripts/smoke.tsx",
    "containers": "node --import tsx scripts/gen-containers.tsx",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@google/model-viewer": "^3.5.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  }
}
