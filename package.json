{
  "name": "mbezu-frontend",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "Production frontend for mbezu.ru (Mila Bezú) — Vite + React, per-page chunks, prerender, SEO.",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node --import tsx scripts/prerender.tsx && node scripts/gen-entry-loaders.mjs",
    "build:only": "vite build",
    "prerender": "node --import tsx scripts/prerender.tsx",
    "smoke": "node --import tsx scripts/smoke.tsx",
    "containers": "node --import tsx scripts/gen-containers.tsx",
    "audit": "node scripts/audit.mjs",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@google/model-viewer": "^3.5.0",
    "@types/node": "^20.19.41",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "chrome-launcher": "^1.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.6.0",
    "lighthouse": "^12.8.2",
    "playwright": "^1.60.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.60.1",
    "vite": "^5.4.2",
    "vitest": "^2.1.9"
  }
}
